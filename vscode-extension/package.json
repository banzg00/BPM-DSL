{
  "name": "flg-language-support",
  "displayName": "FlowGen Language Support",
  "description": "Language support for Business Process Modeling Language (FlowGen)",
  "version": "0.1.0",
  "publisher": "flg",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "flg",
    "business process",
    "dsl",
    "workflow"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "flg",
        "aliases": [
          "FlowGen"
        ],
        "extensions": [
          ".flg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flg",
        "scopeName": "source.flg",
        "path": "./syntaxes/flg.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flg",
        "path": "./snippets/flg.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/flg-vscode"
  },
  "license": "MIT"
}
